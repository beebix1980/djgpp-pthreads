 	pushl	$_frame_struct
 	pushl	$_CRT0_EH_FRAME_BEGIN_
 	call	___register_frame_info
diff -Naur old/src/libc/crt0/crt1.c new/src/libc/crt0/crt1.c
--- old/src/libc/crt0/crt1.c	2015-05-02 06:32:19.000000000 +0200
+++ new/src/libc/crt0/crt1.c	2025-02-03 19:09:54.398742914 +0100
@@ -208,9 +208,10 @@
   _osminor = v & 0xff;
 }
 
+void __crt1_initialize(void);
 
 void
-__crt1_startup(void)
+__crt1_initialize(void)
 {
   __bss_count ++;
   __crt0_argv = 0;
@@ -231,6 +232,11 @@
   __crt0_setup_arguments();
