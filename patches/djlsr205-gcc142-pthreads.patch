diff -Naur old/src/libc/crt0/crt0.S new/src/libc/crt0/crt0.S
--- old/src/libc/crt0/crt0.S	2015-05-02 06:32:19.000000000 +0200
+++ new/src/libc/crt0/crt0.S	2025-02-03 19:11:10.171961261 +0100
@@ -322,6 +322,7 @@
 	movl	%eax, __stklen		/* store the actual stack length */
 
 	xorl	%ebp, %ebp
