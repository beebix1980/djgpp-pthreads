# This patch is for binutils (2.44) and will modify the section
# alignment for the coff-go32 and coff-go32-exe file formats
# from 16 to 64 bytes.
#
diff -Naur old/bfd/coff-go32.c new/bfd/coff-go32.c
--- old/bfd/coff-go32.c	2025-02-02 01:00:00.000000000 +0100
+++ new/bfd/coff-go32.c	2025-03-15 05:48:22.347294734 +0100
@@ -29,23 +29,23 @@
 
 #define COFF_SECTION_ALIGNMENT_ENTRIES \
 { COFF_SECTION_NAME_PARTIAL_MATCH (".data"), \
-  COFF_ALIGNMENT_FIELD_EMPTY, COFF_ALIGNMENT_FIELD_EMPTY, 4 }, \
+  COFF_ALIGNMENT_FIELD_EMPTY, COFF_ALIGNMENT_FIELD_EMPTY, 6 }, \
 { COFF_SECTION_NAME_PARTIAL_MATCH (".text"), \
-  COFF_ALIGNMENT_FIELD_EMPTY, COFF_ALIGNMENT_FIELD_EMPTY, 4 }, \
+  COFF_ALIGNMENT_FIELD_EMPTY, COFF_ALIGNMENT_FIELD_EMPTY, 6 }, \
